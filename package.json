{
	"name": "cspell-dicts-roblox",
	"version": "1.0.0",
	"license": "MIT",
	"author": "Christopher Buss <christopher.buss@pm.me> (https://github.com/christopher-buss)",
	"type": "module",
	"scripts": {
		"build:all": "turbo run build",
		"build:readme": "pnpm run readme:generate-doc-dictionaries && pnpm run readme:inject",
		"changeset": "changeset",
		"check-spelling": "cspell",
		"create-dictionary": "generator-cspell-dicts",
		"lint": "pnpm run lint:fix && cspell --no-progress",
		"lint:fix": "eslint --fix --cache",
		"lint-ci": "eslint . && cspell --no-progress",
		"prepare": "simple-git-hooks && turbo run prepare:dictionary",
		"publish": "turbo run build && changeset publish",
		"readme:generate-doc-dictionaries": "sh scripts/dictionaries.sh > dictionaries.md && eslint --fix dictionaries.md",
		"readme:inject": "inject-markdown \"*.md\" \"dictionaries/*/README.md\"",
		"test": "turbo run test",
		"version": "changeset version"
	},
	"simple-git-hooks": {
		"pre-commit": "pnpm lint-staged"
	},
	"lint-staged": {
		"*": "eslint --fix --cache --no-warn-ignored"
	},
	"devDependencies": {
		"@changesets/cli": "catalog:dev",
		"@cspell/cspell-tools": "catalog:lint",
		"@isentinel/eslint-config": "catalog:lint",
		"cspell": "catalog:lint",
		"eslint": "catalog:lint",
		"eslint-plugin-pnpm": "catalog:lint",
		"generator-cspell-dicts": "catalog:lint",
		"inject-markdown": "catalog:dev",
		"jiti": "catalog:dev",
		"json5": "catalog:dev",
		"lint-staged": "catalog:lint",
		"pncat": "catalog:dev",
		"scripts": "link:scripts",
		"shx": "catalog:dev",
		"simple-git-hooks": "catalog:dev",
		"tsx": "catalog:dev",
		"turbo": "catalog:dev"
	},
	"packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
	"engines": {
		"node": ">=22"
	}
}
